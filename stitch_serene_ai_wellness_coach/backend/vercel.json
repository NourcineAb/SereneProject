{
  "rewrites": [
    {
      "source": "/api/cron/(.*)",
      "destination": "/api/cron"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-checkin",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    },
    "api/cron.py": {
      "maxDuration": 60
    }
  }
}
