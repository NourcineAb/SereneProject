# ─── Serene backend environment ───────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# NOTE: dotenv keeps inline "# comments" as part of the value — keep comments on
# their own line, and values bare.

# Database (matches docker-compose service "db")
DATABASE_URL=postgresql+asyncpg://serene:serene@db:5432/serene

# Auth
JWT_SECRET=change-me-to-a-long-random-string
# JWT lifetime in minutes (10080 = 7 days)
JWT_EXPIRE_MINUTES=10080
ACCESS_TOKEN_ALGO=HS256

# ─── LLM providers (Gemini + OpenRouter FREE models only — no Claude/OpenAI) ───
# Primary provider: "gemini" or "openrouter"
LLM_PRIMARY=gemini
# Google AI Studio key (free tier). https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# OpenRouter key. Use only :free models. https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Monetization: iap | ads | both. Keep consistent with the app's EXPO_PUBLIC_MONETIZATION.
#   iap  = enforce the weekly session gate, sell Pro on the paywall
#   ads  = no weekly gate (free is unlimited, ad-supported on the client)
#   both = weekly gate AND ads for free users
MONETIZATION_MODE=iap

# Freemium
FREE_SESSIONS_PER_WEEK=3
# Leave PREMIUM_PRICE_LABEL commented: a literal "$" breaks docker-compose
# interpolation. Code default is "$4.99/month"; under compose escape as $$4.99/month.
# PREMIUM_PRICE_LABEL=4.99 USD/month

# RevenueCat webhook shared secret.
# Set this to the value you configure in RevenueCat → Project → Integrations → Webhooks → Authorization header.
REVENUECAT_WEBHOOK_SECRET=

# CORS (comma-separated). Use * for local dev with Expo.
CORS_ORIGINS=*

# ─── Hardening ────────────────────────────────────────────────────────────────
# "development" or "production". In production the app refuses to boot with a weak
# JWT_SECRET, with mock billing enabled, or with CORS=*.
ENVIRONMENT=development
# Dev-only escape hatch so the Expo Go / web mock paywall works. MUST be false in prod.
ALLOW_MOCK_BILLING=true
