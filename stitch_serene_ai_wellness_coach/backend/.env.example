# ─── Serene backend environment ───────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# On Vercel, set these via the Dashboard → Settings → Environment Variables.
# NOTE: dotenv keeps inline "# comments" as part of the value — keep comments on
# their own line, and values bare.

# ─── Database ─────────────────────────────────────────────────────────────────
# For Vercel (serverless), use the Supabase **Pooler** URL (port 6543):
#   DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# For local dev / Docker, use the direct connection:
#   DATABASE_URL=postgresql+asyncpg://serene:serene@db:5432/serene
DATABASE_URL=postgresql+asyncpg://serene:serene@db:5432/serene

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
# JWT lifetime in minutes (10080 = 7 days)
JWT_EXPIRE_MINUTES=10080
ACCESS_TOKEN_ALGO=HS256

# ─── LLM providers (Gemini + OpenRouter FREE models only — no Claude/OpenAI) ──
# Primary provider: "gemini", "openrouter", or "nvidia"
LLM_PRIMARY=gemini
# Google AI Studio key (free tier). https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# OpenRouter key. Use only :free models. https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# NVIDIA NIM (optional)
NVIDIA_API_KEY=
NVIDIA_MODEL=stepfun-ai/step-3.7-flash

# ─── Monetization ─────────────────────────────────────────────────────────────
# iap | ads | both. Keep consistent with the app's EXPO_PUBLIC_MONETIZATION.
MONETIZATION_MODE=iap
FREE_SESSIONS_PER_WEEK=3
ALLOW_MOCK_BILLING=true

# RevenueCat webhook shared secret.
REVENUECAT_WEBHOOK_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use * for local dev with Expo.
# In production on Vercel, set to your app's domain(s):
#   CORS_ORIGINS=https://serene.vercel.app,https://serene.app
CORS_ORIGINS=*

# ─── Hardening ────────────────────────────────────────────────────────────────
# "development" or "production". In production the app refuses to boot with a
# weak JWT_SECRET, mock billing, or CORS=*.
ENVIRONMENT=development

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# Shared secret for the /push/daily-checkin cron endpoint.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set in Vercel dashboard; Vercel Cron injects it as Bearer token.
CRON_SECRET=

# ─── Field encryption ─────────────────────────────────────────────────────────
# Fernet base64 key for encrypting PII at rest (messages, notes, journal).
# Required in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Left empty in development — emails are logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Serene <no-reply@serene.app>
APP_BASE_URL=http://localhost:8081
