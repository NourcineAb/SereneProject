# URL of the Serene backend. For a physical device use your machine's LAN IP,
# e.g. http://192.168.1.20:8081  (localhost only works in the web/simulator).
EXPO_PUBLIC_API_URL=http://localhost:8081

# RevenueCat public API key — optional.
# When set, the paywall uses react-native-purchases (requires a custom dev build).
# Leave unset to run in mock mode (Expo Go compatible).
# EXPO_PUBLIC_REVENUECAT_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Monetization mode ────────────────────────────────────────────────────────
# One of: iap | ads | both
# iap  → RevenueCat paywall only (default)
# ads  → AdMob banners + interstitials, no paywall gate
# both → AdMob for free users + RevenueCat upgrade removes ads
# Keep consistent with the backend MONETIZATION_MODE env var.
# EXPO_PUBLIC_MONETIZATION=iap

# AdMob App IDs (required in app.json plugin; safe Google test IDs ship by default).
# Replace with your real IDs for production builds.
# EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
# EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511

# AdMob unit IDs — leave blank to use the library's built-in TestIds automatically.
# EXPO_PUBLIC_ADMOB_BANNER_ID=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=
